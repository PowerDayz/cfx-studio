{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": false,
		"sourceMap": false,
		"outDir": "dist",
		"rootDir": "src",
		"types": ["node"],
		"forceConsistentCasingInFileNames": true,
		"noImplicitOverride": true,
		"noUnusedLocals": true,
		"noUnusedParameters": false,
		"noImplicitReturns": true
	},
	"include": ["src/**/*.ts"]
}
