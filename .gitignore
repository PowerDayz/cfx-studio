# --- Cfx Studio build artifacts ---------------------------------------
# Portable Node 20.18 downloaded by cfx-scripts/ensure-node.mjs.
.toolchain/


# Output of build-fxgraph-webview — Vite bundle for the .fxgraph webview.
# The source under .../webview/src/ stays tracked.
src/vs/workbench/contrib/cfx/browser/graph/media/
# Vite reinstalls the webview's deps each build then wipes them; the
# generated lockfile churns and adds nothing reviewable.
src/vs/workbench/contrib/cfx/browser/graph/webview/package-lock.json
src/vs/workbench/contrib/cfx/browser/graph/webview/node_modules/

# cfx-mcp standalone binary build output. The bundled natives JSON
# (cfx-mcp/data/natives-*.json) IS tracked so a fresh clone has a
# working offline binary without needing cfx:fetch-natives first.
cfx-mcp/dist/
